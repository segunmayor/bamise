{
    "name": "bamise/bamise",
    "description": "Secure enterprise CRUD library for PHP 8.4+ — hexagonal architecture, DDD, PSR standards, JWT/CSRF/XSS protection, event system.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "crud",
        "repository",
        "ddd",
        "hexagonal",
        "security",
        "psr",
        "event",
        "php8",
        "enterprise"
    ],
    "homepage": "https://github.com/bamise/bamise",
    "authors": [
        {
            "name": "Segun Mayor",
            "email": "lungu.sports.entertainment@gmail.com",
            "role": "Developer"
        }
    ],
    "support": {
        "issues": "https://github.com/bamise/bamise/issues",
        "source": "https://github.com/bamise/bamise"
    },
    "require": {
        "php": "^8.4",
        "psr/container": "^2.0",
        "psr/log": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11",
        "phpstan/phpstan": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.0",
        "infection/infection": "^0.29"
    },
    "autoload": {
        "psr-4": {
            "Bamise\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Bamise\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --no-coverage",
        "test-coverage": "phpunit --coverage-clover coverage.xml",
        "analyse": "phpstan analyse --memory-limit=512M",
        "cs-check": "php-cs-fixer check --ansi --diff",
        "cs-fix": "php-cs-fixer fix --ansi",
        "mutation": "infection --min-msi=70 --min-covered-msi=80 --threads=4",
        "ci": [
            "@test",
            "@analyse",
            "@cs-check"
        ]
    },
    "scripts-descriptions": {
        "test": "Run PHPUnit test suite (no coverage)",
        "test-coverage": "Run PHPUnit with Clover coverage report",
        "analyse": "Run PHPStan static analysis",
        "cs-check": "Check code style (PHP CS Fixer, dry-run)",
        "cs-fix": "Auto-fix code style violations",
        "mutation": "Run Infection mutation test suite",
        "ci": "Run test + analyse + cs-check (mirrors CI pipeline)"
    },
    "suggest": {
        "firebase/php-jwt": "^6.10 for JwtAuthAdapter (HS256 bearer validation)"
    },
    "extra": {
        "branch-alias": {
            "dev-master": "0.1.x-dev",
            "dev-main": "0.1.x-dev"
        }
    },
    "minimum-stability": "stable",
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "infection/extension-installer": true
        }
    }
}

{
    "name": "bamise/framework",
    "description": "Secure enterprise CRUD library for PHP 8.4+ — hexagonal architecture, DDD, PSR standards, JWT/CSRF/XSS protection, event system.",
    "type": "library",
    "license": "GPL-3.0-or-later",
    "keywords": [
        "crud",
        "repository",
        "ddd",
        "hexagonal",
        "security",
        "psr",
        "event",
        "php8",
        "enterprise",
        "bamise"
    ],
    "homepage": "https://github.com/segunmayor/bamise.git",
    "authors": [
        {
            "name": "Segun Mayor",
            "email": "segunmayor4331@gmail.com",
            "role": "Developer"
        }
    ],
    "support": {
        "issues": "https://github.com/segunmayor/bamise.git/issues",
        "source": "https://github.com/segunmayor/bamise.git"
    },
    "require": {
        "php": "^8.4",
        "psr/container": "^2.0",
        "psr/log": "^3.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.0",
        "infection/infection": "^0.29",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^11",
        "squizlabs/php_codesniffer": "^3.11",
        "vimeo/psalm": "^6.16"
    },
    "autoload": {
        "psr-4": {
            "Bamise\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Bamise\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --no-coverage",
        "test-coverage": "phpunit --coverage-clover coverage.xml",
        "analyse": "phpstan analyse --memory-limit=512M",
        "cs-check": "php-cs-fixer check --ansi --diff",
        "cs-fix": "php-cs-fixer fix --ansi",
        "phpcs": "phpcs --standard=phpcs.xml",
        "phpcbf": "phpcbf --standard=phpcs.xml",
        "psalm": "psalm --no-progress",
        "mutation": "infection --min-msi=70 --min-covered-msi=80 --threads=4",
        "ci": [
            "@test",
            "@analyse",
            "@psalm",
            "@cs-check",
            "@phpcs"
        ]
    },
    "scripts-descriptions": {
        "test": "Run PHPUnit test suite (no coverage)",
        "test-coverage": "Run PHPUnit with Clover coverage report",
        "analyse": "Run PHPStan static analysis",
        "cs-check": "Check code style (PHP CS Fixer, dry-run)",
        "cs-fix": "Auto-fix code style violations",
        "phpcs": "Check PSR-12 compliance (PHP_CodeSniffer)",
        "phpcbf": "Auto-fix PSR-12 violations (PHP_CodeSniffer)",
        "psalm": "Run Psalm strict static analysis (level 1)",
        "mutation": "Run Infection mutation test suite",
        "ci": "Run test + analyse + cs-check (mirrors CI pipeline)"
    },
    "suggest": {
        "firebase/php-jwt": "^6.10 for JwtAuthAdapter (HS256 bearer validation)"
    },
    "extra": {
        "branch-alias": {
            "dev-master": "0.1.x-dev",
            "dev-main": "0.1.x-dev"
        }
    },
    "minimum-stability": "stable",
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "infection/extension-installer": true
        }
    }
}
